# Non-secret pointer file for local operator credentials.
# Copy to .regime-operator.env for a workspace override, or to
# ~/.config/regime-detection/operator.env to reuse across Conductor workspaces.
#
# Secret values stay in the referenced files. Do not put raw API keys here.

# Load all credential env files in order. Later files fill only missing vars;
# already-set process env vars are not overwritten.
REGIME_ENV_FILES=/path/to/market-data-hub.env:/path/to/signal-engine.env

# Optional provider-specific pointers. Use these when a credential family lives
# in its own file instead of REGIME_ENV_FILES.
# REGIME_ALPACA_ENV=/path/to/alpaca.env
# REGIME_FRED_ENV=/path/to/fred.env
# REGIME_TINYFISH_ENV=/path/to/tinyfish.env
# REGIME_ACLED_ENV=/path/to/acled.env
# REGIME_UCDP_ENV=/path/to/ucdp.env
# REGIME_HDX_ENV=/path/to/hdx-operator-identity.env
# REGIME_INVESTING_ENV=/path/to/investing.env

# Repo-known credential variables consumed by fetch/materialization paths:
# ALPACA_API_KEY_ID
# ALPACA_API_SECRET_KEY
# FRED_API_KEY
# TINYFISH_API_KEY
# ACLED_API_TOKEN
# ACLED_USERNAME
# ACLED_PASSWORD
# UCDP_ACCESS_TOKEN

# HDX HAPI uses an operator app identifier query parameter, not an auth secret.
# Provide either the precomputed identifier or app name/email for the runner to
# derive one.
# HDX_HAPI_APP_IDENTIFIER
# HDX_HAPI_APP_NAME
# HDX_HAPI_APP_EMAIL
# INVESTING_EARNINGS_ACCESS_TOKEN
# INVESTING_EARNINGS_LOADED_PAGE
# INVESTING_BROWSER_USER_DATA_DIR
# INVESTING_BROWSER_EXECUTABLE
# INVESTING_BROWSER_HEADLESS
# INVESTING_BROWSER_TIMEOUT_MS
